# Example backup config.
# Copy to /etc/<project>-backup/backup.env and replace placeholders.
# Do not commit the real file.

PROJECT_NAME="example-project"
PROJECT_ROOT="/opt/example-project"

BACKUP_CONFIG_DIR="/etc/example-project-backup"
BACKUP_STATE_DIR="/var/lib/example-project-backup"
RESTORE_ROOT="/var/lib/example-project-restore"

RCLONE_CONFIG="/etc/example-project-backup/rclone.conf"
RESTIC_PASSWORD_FILE="/etc/example-project-backup/restic-password"
RESTIC_REPOSITORY="rclone:gdrive:ExampleProject-Backups/restic"
RESTIC_CACHE_DIR="/var/lib/example-project-backup/restic-cache"

# Retention
RESTIC_KEEP_HOURLY="48"
RESTIC_KEEP_DAILY="30"
RESTIC_KEEP_WEEKLY="12"
RESTIC_KEEP_MONTHLY="12"

# Telegram placeholders. Never commit real values.
TELEGRAM_BACKUP_BOT_TOKEN="<secret>"
TELEGRAM_BACKUP_CHAT_ID="<chat-id>"

# Project-specific data paths.
DATABASE_CONTAINER="db"
DATABASE_NAME="example_db"
DATABASE_USER="example_user"
PRODUCTION_ENV_FILE="/opt/example-project/.env"
UPLOADS_PATH="/opt/example-project/uploads"

