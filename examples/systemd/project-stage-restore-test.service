[Unit]
Description=Example Project stage restore-lab test
Wants=network-online.target
After=network-online.target docker.service

[Service]
Type=oneshot
User=root
Group=root
EnvironmentFile=/etc/example-project-backup/backup.env

# This service is intended for a Stage Restore Server, not production.
# The restore script must restore into isolated staging/test resources only.
ExecStart=/opt/example-project/ops/backup/restore.sh test latest

Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7

